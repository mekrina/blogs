/* 时间戳转成时间格式 */
function getTime(date, type, fmt) {
    if(!date){
        return new Date().toLocaleString()
    }
    return new Date(date).toLocaleString()
    return fmt
}
var transTime = function (date) {
    // match 2018/10/17 01:48:52"
    if (date.match(/^\d{4}[-/]\d{2}[-/]\d{2} \d{2}:\d{2}:\d{2}$/)) {
        date = date.replace(/-/g, '/') // for safari
        // 如果匹配到服务器返回的时间是非标准格式的祖鲁时间，需要进行本地化
        date = +new Date(date) - timeOffset
    }
    return new Date(date)
}
var timeTips = function (date) {
    if (typeof date === 'string') {
        date = transTime(date)
    }
    const time = new Date(date)
    const offset = (new Date().getTime() - time) / 1000

    if (offset < 60) return trans('time.1分钟内')
    if (offset < 3600) return ~~(offset / 60) + trans('time.分钟前')
    if (offset < 3600 * 24) return ~~(offset / 3600) + trans('time.小时前')
    // 根据 time 获取到 "16:57"
    let timeStr, dateStr
    try {
        timeStr = time.toTimeString().match(/^\d{2}:\d{2}/)[0]
        dateStr = time
            .toLocaleDateString() // > "2018/10/19"
            .replace(/^\d{4}\/(\d{2})\/(\d{2})/, '$1-$2') // > 10-19
    } catch (e) {
        // console.warn('time2tips error: ', { date, time }) // eslint-disable-line no-console
        return ''
    }
    if (offset < 3600 * 24 * 2) return trans('time.昨天') + timeStr
    if (offset < 3600 * 24 * 9) return ~~(offset / 3600 / 24) + trans('time.天前')

    return trans('time.1分钟内')
}

