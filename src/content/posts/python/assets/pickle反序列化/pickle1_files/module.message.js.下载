// 聊天侧边顺序
function checkSideOrder(text) {
    var chatItem = $('#chat_left_message .current_room')
    if (chatItem) {
        chatItem.find('.last_chat_time').text(timeTips(new Date()))
        console.log()
        chatItem.find('.last_content').html(text)
        chatItem.prependTo('#chat_left_message ul')
    }
}
