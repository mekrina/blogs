        }

        _this = Blob.call(this, chunks, opts) || this;
        _this.lastModifiedDate = new Date();
        _this.lastModified = +_this.lastModifiedDate;
        _this.name = filename;
        return _this;
    };
    File.prototype = (function () {
        function fn() {
        }

        fn.prototype = Blob.prototype;
        return new fn;
    }());
    File.prototype.constructor = Blob;
}
